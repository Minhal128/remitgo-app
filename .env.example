# OAuth Configuration
# Copy this file to .env and fill in your actual values

# Clerk Configuration
# Get this from: https://dashboard.clerk.com/ -> API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Google OAuth Configuration
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=your_google_client_secret
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_SECRET=your_google_web_client_secret
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com

# Facebook OAuth
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=your_facebook_client_token
EXPO_PUBLIC_FACEBOOK_APP_SECRET=your_facebook_app_secret

# Backend API
EXPO_PUBLIC_API_BASE_URL=https://remitgobackend.vercel.app

# App Configuration
EXPO_PUBLIC_APP_SCHEME=com.minhal128.remitgo
EXPO_PUBLIC_REDIRECT_URI=com.minhal128.remitgo://oauth-callback

# Backend OAuth Handler (for server deployment)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
